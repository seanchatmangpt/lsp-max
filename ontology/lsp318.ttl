lsp:textDocument_hover a lsp:Request ;
    lsp:methodName "textDocument/hover" ;
    lsp:snakeName  "text_document_hover" ;
    lsp:paramType  "HoverParams" ;
    lsp:returnType "Option<Hover>" ;
    lsp:capability "hover_provider" ;
    law:status     law:CANDIDATE .

