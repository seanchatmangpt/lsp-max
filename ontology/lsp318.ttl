@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix lsp:  <https://lsp-max.rs/ontology/> .
@prefix law:  <https://lsp-max.rs/law/> .

# ── Ontology declaration ──────────────────────────────────────────────────────

<https://lsp-max.rs/ontology/> a owl:Ontology ;
    rdfs:label   "LSP 3.18 Method Ontology" ;
    rdfs:comment "Exhaustive declaration of LSP 3.18 requests and notifications for ggen." .

# ── Core classes ─────────────────────────────────────────────────────────────

lsp:Request      a owl:Class ; rdfs:label "Request" .
lsp:Notification a owl:Class ; rdfs:label "Notification" .
lsp:MaxExtension a owl:Class ; rdfs:label "MaxExtension" .

# ── Shared properties ─────────────────────────────────────────────────────────

lsp:methodName a owl:DatatypeProperty ;
    rdfs:domain lsp:Request ;
    rdfs:range  xsd:string .

lsp:paramType a owl:DatatypeProperty ;
    rdfs:range xsd:string .

lsp:returnType a owl:DatatypeProperty ;
    rdfs:range xsd:string .

lsp:capability a owl:DatatypeProperty ;
    rdfs:range xsd:string .

lsp:snakeName a owl:DatatypeProperty ;
    rdfs:range xsd:string .

# ─────────────────────────────────────────────────────────────────────────────
