lsp:initialize a lsp:Request ;
    lsp:methodName "initialize" ;
    lsp:snakeName  "initialize" ;
    lsp:paramType  "InitializeParams" ;
    lsp:returnType "InitializeResult" ;
    law:status     law:CANDIDATE .

lsp:shutdown a lsp:Request ;
    lsp:methodName "shutdown" ;
    lsp:snakeName  "shutdown" ;
    lsp:paramType  "()" ;
    lsp:returnType "()" ;
    law:status     law:CANDIDATE .

lsp:initialized a lsp:Notification ;
    lsp:methodName "initialized" ;
    lsp:snakeName  "initialized" ;
    lsp:paramType  "InitializedParams" ;
    law:status     law:CANDIDATE .

