PREFIX lsp: <https://lsp-max.rs/ontology/>
PREFIX law: <https://lsp-max.rs/law/>

SELECT ?method_name ?capability_field ?law_status
WHERE {
    ?method a lsp:Request ;
            lsp:methodName ?method_name ;
            lsp:capability ?capability_field ;
            law:status     ?status_iri .
    BIND(STRAFTER(STR(?status_iri), "https://lsp-max.rs/law/") AS ?law_status)
    FILTER(?law_status IN ("CANDIDATE", "ADMITTED"))
}
ORDER BY ?law_status ?method_name
