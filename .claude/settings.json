{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|TaskCreate|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "lsp-max-cli gate check"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/sac/lsp-max && lsp-max-cli diagnostic snapshot 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
