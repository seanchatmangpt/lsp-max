{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/discover-lsp-chains.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/compositor-start.sh",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|TaskCreate|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/gate-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "command -v lsp-max-cli >/dev/null 2>&1 && lsp-max-cli diagnostic snapshot 2>/dev/null || true"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "lsp-max\\.toml$",
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "lsp-max",
            "tool": "lsp_reload_config",
            "input": {}
          }
        ]
      }
    ]
  }
}
