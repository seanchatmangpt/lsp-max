//! Agent property tests — AUTO-GENERATED by ggen agent-layers pack
//! Status: CANDIDATE — receipt chain OPEN
//!
//! Uses chicago-tdd-tools AAA pattern to validate agent definitions.

#[cfg(test)]
mod agent_properties {
    /// Static agent definition for property testing.
    #[derive(Debug, Clone)]
    pub struct AgentDef {
        pub name:        &'static str,
        pub description: &'static str,
        pub layer_depth: u8,
        pub model:       &'static str,
        pub tools:       Option<&'static str>,
        pub law_status:  &'static str,
    }

    /// All agents declared in the ontology.
    pub const AGENTS: &[AgentDef] = &[
{% for row in results %}
        AgentDef {
            name:        "{{ row.agent_name }}",
            description: "{{ row.agent_description | replace(from='"', to='\\"') }}",
            layer_depth: {{ row.layer_depth }},
            model:       "{{ row.agent_model | default(value='inherit') }}",
            tools:       {% if row.agent_tools and row.agent_tools != "" %}Some("{{ row.agent_tools }}"){% else %}None{% endif %},
            law_status:  "{{ row.law_status | default(value='CANDIDATE') }}",
        },
{% endfor %}
    ];

    // ── AAA: Agent name invariants ────────────────────────────────────────────

    #[test]
    fn agent_names_are_lowercase_hyphenated() {
        // Arrange
        let invalid: Vec<&str> = AGENTS
            .iter()
            .filter(|a| {
                // Act: check name chars
                a.name.chars().any(|c| c.is_uppercase() || c == '_')
            })
            .map(|a| a.name)
            .collect();
        // Assert
        assert!(
            invalid.is_empty(),
            "Agent names must be lowercase/hyphenated. Violations: {:?}",
            invalid
        );
    }

    #[test]
    fn agent_names_within_64_chars() {
        // Arrange + Act + Assert (AAA collapsed for simple bound check)
        for agent in AGENTS {
            assert!(
                agent.name.len() <= 64,
                "Agent '{}' name exceeds 64 chars ({})",
                agent.name, agent.name.len()
            );
        }
    }

    #[test]
    fn agent_names_exclude_reserved_words() {
        for agent in AGENTS {
            assert!(
                !agent.name.contains("anthropic") && !agent.name.contains("claude"),
                "Agent name '{}' contains reserved word",
                agent.name
            );
        }
    }

    // ── AAA: Description invariants ───────────────────────────────────────────

    #[test]
    fn descriptions_are_non_empty() {
        for agent in AGENTS {
            assert!(
                !agent.description.is_empty(),
                "Agent '{}' has empty description",
                agent.name
            );
        }
    }

    #[test]
    fn descriptions_within_1024_chars() {
        for agent in AGENTS {
            assert!(
                agent.description.len() <= 1024,
                "Agent '{}' description exceeds 1024 chars ({})",
                agent.name, agent.description.len()
            );
        }
    }

    // ── AAA: Layer depth invariants ───────────────────────────────────────────

    #[test]
    fn layer_depths_in_range_one_to_five() {
        for agent in AGENTS {
            assert!(
                (1..=5).contains(&agent.layer_depth),
                "Agent '{}' has invalid layer_depth {}",
                agent.name, agent.layer_depth
            );
        }
    }

    #[test]
    fn all_five_layers_populated() {
        // Arrange: build a set of present depths
        let present: std::collections::HashSet<u8> =
            AGENTS.iter().map(|a| a.layer_depth).collect();
        // Assert: every depth 1–5 must have at least one agent
        for depth in 1u8..=5 {
            assert!(
                present.contains(&depth),
                "No agent declared at layer depth {}",
                depth
            );
        }
    }

    // ── AAA: Model invariants ─────────────────────────────────────────────────

    #[test]
    fn model_is_known_alias_or_inherit() {
        const VALID_MODELS: &[&str] = &[
            "sonnet", "opus", "haiku", "fable", "inherit",
            // Full IDs
            "claude-sonnet-4-6", "claude-opus-4-8", "claude-haiku-4-5-20251001",
        ];
        for agent in AGENTS {
            let known = VALID_MODELS.iter().any(|m| agent.model.starts_with(m));
            assert!(
                known,
                "Agent '{}' has unrecognised model '{}'. Use: sonnet|opus|haiku|fable|inherit or full ID",
                agent.name, agent.model
            );
        }
    }

    #[test]
    fn leaf_agents_have_restricted_tools() {
        // Layer 5 agents must not have Write or Edit in tools.
        for agent in AGENTS.iter().filter(|a| a.layer_depth == 5) {
            if let Some(tools) = agent.tools {
                assert!(
                    !tools.contains("Write") && !tools.contains("Edit"),
                    "Leaf agent '{}' must not have Write/Edit tools",
                    agent.name
                );
            }
        }
    }

    // ── AAA: Conformance status ───────────────────────────────────────────────

    #[test]
    fn law_status_is_bounded_vocabulary() {
        const VALID: &[&str] = &[
            "ADMITTED", "CANDIDATE", "BLOCKED", "REFUSED", "UNKNOWN", "PARTIAL", "OPEN",
        ];
        for agent in AGENTS {
            assert!(
                VALID.contains(&agent.law_status),
                "Agent '{}' has non-bounded law_status '{}'. Use: {:?}",
                agent.name, agent.law_status, VALID
            );
        }
    }
}
