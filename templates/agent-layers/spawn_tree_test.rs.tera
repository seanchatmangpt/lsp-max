//! Spawn-tree conformance tests — AUTO-GENERATED by ggen agent-layers pack
//! Source: ontology spawn_tree.sparql + agent definitions
//! Status: CANDIDATE — receipt chain OPEN
//!
//! Validates that the 5-layer agent hierarchy is structurally sound:
//! - Parent depth + 1 == child depth for every spawn edge
//! - No agent at depth 5 has canSpawnType
//! - All spawned agent names resolve to declared agents

#[cfg(test)]
mod spawn_tree {
    /// A spawn edge in the agent hierarchy.
    #[derive(Debug, Clone, PartialEq, Eq)]
    pub struct SpawnEdge {
        pub parent_name:  &'static str,
        pub parent_depth: u8,
        pub child_name:   &'static str,
        pub child_depth:  u8,
    }

    /// All spawn edges declared in the ontology.
    pub const EDGES: &[SpawnEdge] = &[
{% for row in results %}
        SpawnEdge {
            parent_name:  "{{ row.parent_name }}",
            parent_depth: {{ row.parent_depth }},
            child_name:   "{{ row.child_name }}",
            child_depth:  {{ row.child_depth }},
        },
{% endfor %}
    ];

    #[test]
    fn no_leaf_spawns() {
        // Depth-5 agents must not appear as a parent in any spawn edge.
        for edge in EDGES {
            assert_ne!(
                edge.parent_depth, 5,
                "Leaf agent '{}' at depth 5 must not spawn '{}'",
                edge.parent_name, edge.child_name
            );
        }
    }

    #[test]
    fn spawn_only_reaches_adjacent_depth() {
        // Every spawn edge must cross exactly one depth level.
        for edge in EDGES {
            assert_eq!(
                edge.child_depth,
                edge.parent_depth + 1,
                "Spawn edge '{}' → '{}' skips depth: {} → {} (expected {})",
                edge.parent_name,
                edge.child_name,
                edge.parent_depth,
                edge.child_depth,
                edge.parent_depth + 1
            );
        }
    }

    #[test]
    fn max_depth_is_five() {
        // No agent exceeds depth 5.
        for edge in EDGES {
            assert!(edge.parent_depth <= 5, "parent depth {} exceeds 5", edge.parent_depth);
            assert!(edge.child_depth  <= 5, "child  depth {} exceeds 5", edge.child_depth);
        }
    }

    #[test]
    fn spawn_edges_present_for_layers_one_through_four() {
        // Every depth 1-4 should have at least one outgoing spawn edge
        // (a coordinator that never spawns is misconfigured).
        for depth in 1u8..=4 {
            let has_outgoing = EDGES.iter().any(|e| e.parent_depth == depth);
            assert!(
                has_outgoing,
                "No outgoing spawn edges from depth {} — layer is unreachable",
                depth
            );
        }
    }

    #[test]
    fn spawn_tree_edge_count() {
        // Document the total edge count for regression detection.
        let count = EDGES.len();
        assert!(count >= 4, "Expected at least 4 spawn edges (one per layer 1-4), got {count}");
    }
}
