//! Static schema — AUTO-GENERATED by ggen lsp-max pack
//! Source: schema/domain.ttl + queries/schema_fields.sparql
//! Edit the .ttl, run `ggen sync` — never edit this file directly

use std::collections::BTreeMap;

/// Re-export schema types from the base crate
pub use lsp_max::schema::{SchemaNode, PrimitiveType, StaticSchema};

/// Static schema registry for {{ server_name }} LSP.
///
/// This schema defines the type invariants, conformance predicates, and metadata
/// for breed inputs, outputs, and pipeline transformations.
pub static SCHEMA: StaticSchema = StaticSchema {
    name: "{{ server_name }}",
    version: "{{ version }}",
    types: {
        let mut m = BTreeMap::new();
{% for result in results %}
        m.insert(
            "{{ result.class_name }}".to_string(),
            SchemaNode {
                name: "{{ result.class_name }}".to_string(),
                kind: "class".to_string(),
                fields: vec![
                    (
                        "{{ result.field_name }}".to_string(),
                        PrimitiveType {
                            name: "{{ result.field_type }}".to_string(),
                            is_optional: {{ result.optional }},
                            stability: "{{ result.stability }}".to_string(),
                        },
                    ),
                ],
                law_status: "{{ result.law_status }}".to_string(),
            },
        );
{% endfor %}
        m
    },
    description: "{{ description | default(value='') }}",
    invariants: vec![
{% if invariants %}
{% for invariant in invariants %}
        "{{ invariant }}".to_string(),
{% endfor %}
{% endif %}
    ],
    metadata: {
        let mut m = BTreeMap::new();
{% if metadata %}
{% for key, value in metadata %}
        m.insert("{{ key }}".to_string(), "{{ value }}".to_string());
{% endfor %}
{% endif %}
        m
    },
};

/// Access the server schema at runtime.
#[inline]
pub fn get_schema() -> &'static StaticSchema {
    &SCHEMA
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn schema_loads() {
        let schema = get_schema();
        assert_eq!(schema.name, "{{ server_name }}");
        assert_eq!(schema.version, "{{ version }}");
    }

    #[test]
    fn schema_has_fields() {
        let schema = get_schema();
        assert!(
            !schema.types.is_empty(),
            "schema must have at least one type"
        );
    }

    #[test]
    fn schema_resolve_root() {
        let schema = get_schema();
{% if results %}
        // Verify that first class from results can be resolved
        let _ = schema.types.get("{{ results[0].class_name }}");
{% endif %}
    }
}
