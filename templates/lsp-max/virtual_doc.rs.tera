//! `{{ virtual_doc_uri }}` virtual document
//! Generated by ggen lsp-max pack — CANDIDATE
//!
//! Virtual documents are computed on-demand and never mutate files.
//! Status: CANDIDATE — receipt chain OPEN

/// Render the `{{ virtual_doc_uri }}` virtual document content.
pub fn render() -> String {
    "# {{ doc_title }}\n\n*Virtual document — read-only. Rendered from live server state.*\n\n\
     ## Status\n\nServer: {{ server_name }}\n\n\
     *Status: CANDIDATE — receipt chain OPEN*\n".to_string()
}

/// Returns true if the given URI belongs to this virtual document.
pub fn is_virtual_doc_uri(uri: &str) -> bool {
    uri.starts_with("{{ virtual_doc_scheme }}://")
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn virtual_doc_uri_recognized() {
        assert!(is_virtual_doc_uri("{{ virtual_doc_scheme }}://content"));
        assert!(!is_virtual_doc_uri("file:///path/to/file"));
    }

    #[test]
    fn render_is_non_empty() {
        let content = render();
        assert!(!content.is_empty());
        assert!(content.contains("Virtual document"));
    }
}
