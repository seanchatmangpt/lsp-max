//! `{{ virtual_doc_uri }}` virtual document
//! Generated by ggen lsp-max pack — CANDIDATE
//!
//! This module renders a live {{ doc_type }} surface from the current state of
//! the LSP server. Virtual documents are computed on-demand; they never mutate
//! files or persist to disk.

use lsp_types_max::Url;

/// Render the `{{ virtual_doc_uri }}` virtual document content.
///
/// # Arguments
/// * `state` — the current server state (diagnostics, workspace, etc.)
///
/// # Returns
/// A markdown or plaintext string suitable for display in an editor.
pub fn render(state: &crate::ServerState) -> String {
    let mut out = String::new();

    // Header
    out.push_str(&format!("# {}\n\n", "{{ doc_title }}"));
    out.push_str("*Virtual document — read-only. Rendered from live server state.*\n\n");

    // Status summary
    out.push_str("## Status\n\n");
    out.push_str(&format!(
        "| Metric | Value |\n| --- | --- |\n| Rendered at | {} |\n| Server | {} |\n",
        chrono::Local::now().format("%Y-%m-%d %H:%M:%S"),
        "{{ server_name }}"
    ));
    out.push_str("\n");

    // Diagnostics summary (if applicable)
    {% if include_diagnostics %}
    out.push_str("## Diagnostics\n\n");
    let diag_count = state.diagnostics_count();
    if diag_count > 0 {
        out.push_str(&format!("| Code | Count |\n| --- | --- |\n"));
        for (code, count) in state.diagnostics_by_code() {
            out.push_str(&format!("| `{}` | {} |\n", code, count));
        }
    } else {
        out.push_str("No diagnostics active.\n");
    }
    out.push_str("\n");
    {% endif %}

    // Content section
    {% if doc_type == "process-model" %}
    out.push_str("## Process Model\n\n");
    out.push_str("### Activities\n\n");
    out.push_str("The current process mining DFG discovered these activities:\n\n");
    for activity in state.dfg_activities() {
        out.push_str(&format!("- `{}`\n", activity));
    }
    out.push_str("\n");

    out.push_str("### Transitions\n\n");
    out.push_str("```mermaid\n");
    out.push_str(&state.dfg_mermaid());
    out.push_str("\n```\n\n");

    out.push_str("### Conformance\n\n");
    out.push_str("Declare constraint checking against the normative model:\n\n");
    out.push_str("| Constraint | Status |\n| --- | --- |\n");
    for (constraint, status) in state.declare_conformance() {
        out.push_str(&format!("| `{}` | {} |\n", constraint, status));
    }
    out.push_str("\n");
    {% elif doc_type == "lsp318-matrix" %}
    out.push_str("## LSP 3.18 Coverage Matrix\n\n");
    out.push_str("Feature support derived from on-disk evidence (transcripts, receipts, negative controls).\n\n");
    out.push_str("| Feature | Status | Method |\n| --- | --- | --- |\n");
    for row in state.lsp318_matrix() {
        out.push_str(&format!(
            "| `{}` | `{}` | `{}` |\n",
            row.feature, row.status, row.method
        ));
    }
    out.push_str("\n");
    {% elif doc_type == "state-snapshot" %}
    out.push_str("## Workspace State\n\n");
    out.push_str("### Open Documents\n\n");
    for (uri, _doc) in state.open_documents() {
        out.push_str(&format!("- `{}`\n", uri));
    }
    out.push_str("\n");

    out.push_str("### Workspace Folders\n\n");
    for folder in state.workspace_folders() {
        out.push_str(&format!("- `{}`\n", folder.uri));
    }
    out.push_str("\n");
    {% endif %}

    // Footer
    out.push_str("---\n\n");
    out.push_str("*Generated by lsp-max. This document is CANDIDATE and may change as the server evolves.*\n");

    out
}

/// Normalize a virtual document URI to this module's scheme.
pub fn is_virtual_doc_uri(uri: &str) -> bool {
    uri.starts_with("{{ virtual_doc_scheme }}://")
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn virtual_doc_uri_recognized() {
        assert!(is_virtual_doc_uri("{{ virtual_doc_scheme }}://content"));
        assert!(!is_virtual_doc_uri("file:///path/to/file"));
    }

    #[test]
    fn render_does_not_panic() {
        let mock_state = crate::ServerState::new();
        let content = render(&mock_state);
        assert!(!content.is_empty());
        assert!(content.contains("Virtual document"));
    }
}
