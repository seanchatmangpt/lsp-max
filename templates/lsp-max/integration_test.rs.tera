async fn e2e_{{ snake_method }}_requires_init_guard() {
    let (mut service, _) = LspService::build(|_| IntegrationTestServer)
        .finish();

    // Attempt a method call without initialization
    // The service should reject it or return a ServerNotInitialized error
    let req = Request::build("shutdown").id(1).finish();

    let response = service
        .ready()
        .await
        .expect("service ready")
        .call(req)
