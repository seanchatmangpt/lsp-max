/// Test: {{ method_name }} handler initializes and responds
/// Status: {{ law_status | default(value="CANDIDATE") }}
/// Receipt: {{ receipt_path | default(value="OPEN") }}
#[tokio::test]
async fn e2e_{{ snake_method }}_initializes() {
    let (mut service, _) = LspService::build(|_| IntegrationTestServer)
        .finish();

    // Initialize: required before any method call
    let init_req = Request::build("initialize")
        .params(json!({
            "capabilities": {},
            "processId": std::process::id()
        }))
        .id(1)
        .finish();

    let init_response = service
        .ready()
        .await
        .expect("service ready")
        .call(init_req)
        .await
        .expect("initialize request succeeds");

    assert!(init_response.is_some(), "initialize must return a response");
}

/// Test: {{ method_name }} handler can be called after initialization
/// Status: {{ law_status | default(value="CANDIDATE") }}
/// Receipt: {{ receipt_path | default(value="OPEN") }}
#[tokio::test]
async fn e2e_{{ snake_method }}_callable() {
    let (mut service, _) = LspService::build(|_| IntegrationTestServer)
        .finish();

    // Initialize first
    let init_req = Request::build("initialize")
        .params(json!({
            "capabilities": {},
            "processId": std::process::id()
        }))
        .id(1)
        .finish();

    let _ = service
        .ready()
        .await
        .expect("service ready")
        .call(init_req)
        .await;

    // Shutdown is always callable
    let shutdown_req = Request::build("shutdown").id(2).finish();
    let shutdown_response = service
        .ready()
        .await
        .expect("service ready")
        .call(shutdown_req)
        .await
        .expect("shutdown request succeeds");

    assert!(shutdown_response.is_some(), "shutdown must return a response");
}

