/// A Declare constraint type (LTL-based declarative specification).
#[derive(Debug, Clone, PartialEq, Eq)]
pub enum ConstraintType {
    Init,
    End,
    Response,
    Precedence,
    ExactlyOne,
    NotCoExistence,
    RespondedExistence,
    Absence,
    ChainResponse,
    Other(String),
}

impl From<&str> for ConstraintType {
    fn from(s: &str) -> Self {
        match s {
            "Init" => Self::Init,
            "End" => Self::End,
            "Response" => Self::Response,
            "Precedence" => Self::Precedence,
            "ExactlyOne" => Self::ExactlyOne,
            "NotCoExistence" => Self::NotCoExistence,
            "RespondedExistence" => Self::RespondedExistence,
            "Absence" => Self::Absence,
            "ChainResponse" => Self::ChainResponse,
            other => Self::Other(other.to_string()),
        }
    }
}

/// A single Declare constraint.
#[derive(Debug, Clone)]
pub struct DeclareConstraint {
    pub constraint_type: ConstraintType,
    pub antecedent: String,
    pub consequent: Option<String>,
}

/// A Declare model: a named set of constraints over activities.
#[derive(Debug, Clone)]
pub struct DeclareModel {
    pub name: &'static str,
    pub constraints: Vec<DeclareConstraint>,
}

{% if results %}
/// Build the normative Declare model for this server.
///
/// Constraint set: {{ results | length }} constraint(s) from domain ontology.
pub fn declare_model() -> DeclareModel {
    DeclareModel {
        name: "{{ server_name | default(value='server') }}_process_model",
        constraints: vec![
{% for row in results %}
            DeclareConstraint {
                constraint_type: ConstraintType::from("{{ row.constraint_type }}"),
                antecedent: "{{ row.antecedent }}".to_string(),
                consequent: {% if row.consequent and row.consequent != "" %}Some("{{ row.consequent }}".to_string()){% else %}None{% endif %},
            },
{% endfor %}
        ],
    }
}
{% else %}
/// No constraints generated. Add constraint definitions to schema/domain.ttl
/// then run `ggen sync` to populate this module.
pub fn declare_model() -> DeclareModel {
    DeclareModel { name: "empty", constraints: vec![] }
}
{% endif %}

