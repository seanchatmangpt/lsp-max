[package]
name = "{{ name }}"
version = "{{ version | default(value='0.1.0') }}"
edition = "2021"
description = "LSP server generated by ggen + lsp-max pack — CANDIDATE"

[[bin]]
name = "{{ name }}"
path = "src/main.rs"

[lib]
name = "{{ name | replace(from='-', to='_') }}"
path = "src/lib.rs"

[dependencies]
lsp-max = "26.6"
lsp-types-max = { version = "26.6", features = ["proposed"] }
tree-sitter = "0.26"
tree-sitter-json = "0.23"
tokio = { version = "1", features = ["io-std", "io-util", "macros", "rt-multi-thread"] }
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
async-trait = "0.1"
tracing = "0.1"
tracing-subscriber = "0.3"
chrono = { version = "0.4", features = ["serde"] }
blake3 = "1"
