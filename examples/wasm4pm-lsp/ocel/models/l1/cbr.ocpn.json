{
  "$schema": "https://wasm4pm.dev/cognition/ocpn.schema.json",
  "breed_id": "cbr",
  "label": "Case-Based Reasoner OCPN Model",
  "family": "AnalogicalAI",
  "status": "CANDIDATE",
  "places": [
    { "id": "p_case_base",       "label": "CaseBase",        "type": "input" },
    { "id": "p_query",           "label": "Query",           "type": "internal" },
    { "id": "p_weights",         "label": "FeatureWeights",  "type": "internal" },
    { "id": "p_feature_vectors", "label": "FeatureVectors",  "type": "internal" },
    { "id": "p_scored",          "label": "ScoredCases",     "type": "internal" },
    { "id": "p_retrieved",       "label": "RetrievedCase",   "type": "output" }
  ],
  "transitions": [
    {
      "id": "t_extract_vectors",
      "label": "extract_vectors",
      "input_arcs":  [
        { "place": "p_case_base", "weight": 1 },
        { "place": "p_query",     "weight": 1 }
      ],
      "output_arcs": [{ "place": "p_feature_vectors", "weight": 1 }]
    },
    {
      "id": "t_score",
      "label": "score",
      "input_arcs":  [
        { "place": "p_feature_vectors", "weight": 1 },
        { "place": "p_weights",         "weight": 1 }
      ],
      "output_arcs": [{ "place": "p_scored", "weight": 1 }]
    },
    {
      "id": "t_rank",
      "label": "rank",
      "input_arcs":  [{ "place": "p_scored", "weight": 1 }],
      "output_arcs": [{ "place": "p_scored", "weight": 1 }]
    },
    {
      "id": "t_select_best",
      "label": "select_best",
      "input_arcs":  [{ "place": "p_scored",    "weight": 1 }],
      "output_arcs": [{ "place": "p_retrieved", "weight": 1 }]
    }
  ],
  "object_types": ["CaseBase", "Query", "FeatureWeights", "FeatureVectors", "ScoredCases", "RetrievedCase"]
}
