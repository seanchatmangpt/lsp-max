{
  "$schema": "https://wasm4pm.dev/cognition/ocpn.schema.json",
  "breed_id": "mycin",
  "label": "MYCIN Production Rules OCPN Model",
  "family": "RuleBasedAI",
  "status": "CANDIDATE",
  "places": [
    { "id": "p_rules",       "label": "ProductionRules", "type": "input" },
    { "id": "p_evidence",    "label": "ActiveEvidence",  "type": "internal" },
    { "id": "p_query",       "label": "HypothesisQuery", "type": "internal" },
    { "id": "p_fired",       "label": "FiredRules",      "type": "internal" },
    { "id": "p_combined_cf", "label": "CombinedCF",      "type": "internal" },
    { "id": "p_conclusion",  "label": "Conclusion",      "type": "output" }
  ],
  "transitions": [
    {
      "id": "t_match_evidence",
      "label": "match_evidence",
      "input_arcs":  [
        { "place": "p_rules",    "weight": 1 },
        { "place": "p_evidence", "weight": 1 },
        { "place": "p_query",    "weight": 1 }
      ],
      "output_arcs": [{ "place": "p_fired", "weight": 1 }]
    },
    {
      "id": "t_fold_cf",
      "label": "fold_cf",
      "input_arcs":  [{ "place": "p_fired",       "weight": 1 }],
      "output_arcs": [{ "place": "p_combined_cf", "weight": 1 }]
    },
    {
      "id": "t_conclude",
      "label": "conclude",
      "input_arcs":  [{ "place": "p_combined_cf", "weight": 1 }],
      "output_arcs": [{ "place": "p_conclusion",  "weight": 1 }]
    }
  ],
  "object_types": ["ProductionRules", "ActiveEvidence", "HypothesisQuery", "FiredRules", "CombinedCF", "Conclusion"]
}
