{
  "$schema": "https://wasm4pm.dev/cognition/ocpn.schema.json",
  "breed_id": "pomdp",
  "label": "POMDP Solver OCPN Model",
  "family": "ReinforcementLearning",
  "status": "CANDIDATE",
  "places": [
    { "id": "p_belief",         "label": "BeliefState",    "type": "input" },
    { "id": "p_value_fn",       "label": "ValueFunction",  "type": "internal" },
    { "id": "p_alpha_vectors",  "label": "AlphaVectors",   "type": "internal" },
    { "id": "p_action_values",  "label": "ActionValues",   "type": "internal" },
    { "id": "p_updated_v",      "label": "UpdatedValueFn", "type": "internal" },
    { "id": "p_policy",         "label": "OptimalPolicy",  "type": "output" }
  ],
  "transitions": [
    {
      "id": "t_init_v",
      "label": "init_v",
      "input_arcs":  [{ "place": "p_belief",   "weight": 1 }],
      "output_arcs": [{ "place": "p_value_fn", "weight": 1 }]
    },
    {
      "id": "t_bellman_backup",
      "label": "bellman_backup",
      "input_arcs":  [{ "place": "p_value_fn",   "weight": 1 }],
      "output_arcs": [{ "place": "p_updated_v",  "weight": 1 }]
    },
    {
      "id": "t_check_convergence",
      "label": "check_convergence",
      "input_arcs":  [{ "place": "p_updated_v",     "weight": 1 }],
      "output_arcs": [
        { "place": "p_value_fn",      "weight": 1 },
        { "place": "p_alpha_vectors", "weight": 1 }
      ]
    },
    {
      "id": "t_project_belief",
      "label": "project_belief",
      "input_arcs":  [
        { "place": "p_alpha_vectors", "weight": 1 },
        { "place": "p_belief",        "weight": 1 }
      ],
      "output_arcs": [{ "place": "p_action_values", "weight": 1 }]
    },
    {
      "id": "t_greedy_policy",
      "label": "greedy_policy",
      "input_arcs":  [{ "place": "p_action_values", "weight": 1 }],
      "output_arcs": [{ "place": "p_policy",        "weight": 1 }]
    }
  ],
  "object_types": ["BeliefState", "ValueFunction", "AlphaVectors", "ActionValues", "UpdatedValueFn", "OptimalPolicy"]
}
