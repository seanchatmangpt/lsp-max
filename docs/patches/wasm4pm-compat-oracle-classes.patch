+//! Anti-LLM cheating Oracle class witness markers.
+//!
+//! ## Purpose
+//!
+//! These witnesses name the five adversary detection classes used by the
+//! `lsp-max-anti-cheat` tool to identify LLM coding agent cheating patterns
+//! via OCEL-based process mining.
+//!
+//! The Oracle classes (A8–A12) are defined in the `lsp-max` process-mining
+//! threat model and correspond to formally detectable causality violations
+//! in Object-Centric Event Logs emitted by LLM coding sessions.
+//!
+//! ## What these witnesses ARE
+//!
+//! - Structure-only authority labels for each Oracle violation class.
+//! - Type-level tags that travel with `Evidence` and `Admission` values through
+//!   the admission pipeline so a diagnostic can name *which* Oracle class
+//!   flagged a violation.
+//! - Foundation for wasm4pm engine-level Oracle inference (graduate there when
+//!   actual conformance computation is needed).
+//!
+//! ## What these witnesses are NOT
+//!
+//! - **Not** detection logic. Oracle detection belongs in `wasm4pm`. Here we
+//!   name the class; `wasm4pm` verifies it.
+//! - **Not** runtime values. All are uninhabited enums — zero cost.
+//!
+//! ## Oracle Class Definitions
+//!
+//! | Class | Name                  | What it Catches                                    |
+//! |-------|-----------------------|----------------------------------------------------|
+//! | A8    | AuditLogTampering     | Receipts/events without ancestor computation chain |
+//! | A9    | TemporalAnomaly       | Events with impossible timestamps (time travel)    |
+//! | A10   | CausalViolation       | Diagnostics/mutations without causal predecessors  |
+//! | A11   | UnknownStateCollapse  | UNKNOWN → ADMITTED without resolution event        |
+//! | A12   | CyclicDependency      | Circular dependency in the event causality DAG     |
+//!
+//! ## Usage
+//!
+//! ```rust
+//! use wasm4pm_compat::witnesses_anti_cheat::{OracleA8AuditLogTampering, OracleA11UnknownCollapse};
+//! use wasm4pm_compat::witness::Witness;
+//!
+//! assert_eq!(OracleA8AuditLogTampering::KEY, "anti-cheat/oracle-a8-audit-log-tampering");
+//! assert_eq!(OracleA11UnknownCollapse::KEY, "anti-cheat/oracle-a11-unknown-collapse");
+//! ```
+
+use crate::witness::WitnessFamily;
+
+witness_marker!(
+    /// **A8 — Audit Log Tampering**
+    ///
+    /// Catches events or receipts that appear in the OCEL session log without
+    /// a traceable ancestor computation chain. Specifically:
+    ///
+    /// - A `ReceiptGenerated` event with no preceding `Computation`, `Test`, or
+    ///   `Commit` event acting on the same objects.
+    /// - A `Diagnostic` emitted without a corresponding `PatternMatched` event.
+    /// - Hash chain integrity failures (digest mismatch in receipt chain).
+    ///
+    /// **Graduate to `wasm4pm`** to run the actual causal-predecessor traversal
+    /// over the OCEL event graph.
+    OracleA8AuditLogTampering,
+    "anti-cheat/oracle-a8-audit-log-tampering",
+    WitnessFamily::Paper,
+    "A8 Oracle — Audit Log Tampering (lsp-max threat model)",
+    None
+);
+
+witness_marker!(
+    /// **A9 — Temporal Anomaly**
+    ///
+    /// Catches events where the timestamp ordering violates causality. Specifically:
+    ///
+    /// - A `ReceiptGenerated` event timestamped *before* the computation it claims
+    ///   to receipt (the receipt proves something that hadn't happened yet).
+    /// - A `StateTransition` with a timestamp earlier than its predecessor.
+    /// - A `Commit` event with a timestamp before the `FileWrite` events it
+    ///   claims to record.
+    ///
+    /// **Graduate to `wasm4pm`** to run temporal ordering validation over the
+    /// full OCEL event sequence.
+    OracleA9TemporalAnomaly,
+    "anti-cheat/oracle-a9-temporal-anomaly",
+    WitnessFamily::Paper,
+    "A9 Oracle — Temporal Anomaly (lsp-max threat model)",
+    None
+);
+
+witness_marker!(
+    /// **A10 — Causal Violation**
+    ///
+    /// Catches broken dependency chains in the OCEL event causality graph. Specifically:
+    ///
+    /// - A `FileWrite` event with no preceding `FileRead` or `ToolCall(Edit)` on the
+    ///   same file object — the mutation appeared without observation.
+    /// - A `DiagnosticEmitted` event with no parent `PatternMatched` or
+    ///   `ConformanceDeviation` — the diagnostic has no cause.
+    /// - A `ConformanceVectorUpdate` with no preceding analysis event.
+    ///
+    /// **Graduate to `wasm4pm`** to run causal-DAG reachability over the OCEL
+    /// event graph.
+    OracleA10CausalViolation,
+    "anti-cheat/oracle-a10-causal-violation",
+    WitnessFamily::Paper,
+    "A10 Oracle — Causal Violation (lsp-max threat model)",
+    None
+);
+
+witness_marker!(
+    /// **A11 — Unknown State Collapse**
+    ///
+    /// Catches premature resolution of `UNKNOWN` states in conformance vectors
+    /// without supporting evidence. Specifically:
+    ///
+    /// - A `ConformanceVector` law-axis transitioning from `UNKNOWN` to `ADMITTED`
+    ///   or `REFUSED` without a `ResolutionEvent` (test run, receipt validation,
+    ///   or explicit refusal) in the causal chain.
+    /// - A fitness score changing from `null` to `1.0` without a measurement event.
+    /// - Status changing from `CANDIDATE` to `ADMITTED` without a gate-clear event.
+    ///
+    /// This is the structural guard for `ConformanceVector`'s core invariant:
+    /// Unknown must never collapse into Admitted or Refused.
+    ///
+    /// **Graduate to `wasm4pm`** to run state-machine conformance over the
+    /// typestate transitions in the session log.
+    OracleA11UnknownCollapse,
+    "anti-cheat/oracle-a11-unknown-collapse",
+    WitnessFamily::Paper,
+    "A11 Oracle — Unknown State Collapse (lsp-max threat model)",
+    None
+);
+
+witness_marker!(
+    /// **A12 — Cyclic Dependency**
+    ///
+    /// Catches circular causality in the OCEL event graph. Specifically:
+    ///
+    /// - Tool A calls Tool B which calls Tool A — cycle in tool dispatch DAG.
+    /// - Object A depends on Object B which depends on Object A — cycle in
+    ///   object reference graph.
+    /// - A `StateTransition` chain forms a loop (e.g. READY → EXECUTING → READY
+    ///   without a valid re-entry event).
+    ///
+    /// A valid OCEL causality graph is a DAG; any cycle is a structural impossibility
+    /// that signals either log manipulation or a modeling error.
+    ///
+    /// **Graduate to `wasm4pm`** to run cycle detection over the event causality DAG.
+    OracleA12CyclicDependency,
+    "anti-cheat/oracle-a12-cyclic-dependency",
+    WitnessFamily::Paper,
+    "A12 Oracle — Cyclic Dependency (lsp-max threat model)",
+    None
+);
+
+// ── Session Event Type Witnesses ───────────────────────────────────────────────
+
+witness_marker!(
+    /// **LspMaxSessionWitness** — the authority label for OCEL events emitted
+    /// by an lsp-max coding session.
+    ///
+    /// When an LLM coding session emits an OCEL log (FileRead, FileWrite, ToolCall,
+    /// StateTransition, etc.), these events are tagged with this witness to identify
+    /// them as session-provenance rather than process-mining provenance.
+    ///
+    /// **Graduate to `wasm4pm`** to run Oracle inference over the session OCEL.
+    LspMaxSessionWitness,
+    "anti-cheat/lsp-max-session",
+    WitnessFamily::InternalBridge,
+    "lsp-max Session OCEL Authority",
+    None
+);
+
+witness_marker!(
+    /// **AntiLlmScanWitness** — the authority label for OCEL events emitted by
+    /// the `lsp-max-anti-cheat` scanner.
+    ///
+    /// When `lsp-max-anti-cheat` scans a file and emits `FileScanned` and
+    /// `PatternMatched` events into an OCEL log, these events are tagged with this
+    /// witness. The OCEL log then flows to `wasm4pm` for Oracle class inference.
+    ///
+    /// **Graduate to `wasm4pm`** to run A8–A12 Oracle inference over the scan log.
+    AntiLlmScanWitness,
+    "anti-cheat/anti-llm-scan",
+    WitnessFamily::InternalBridge,
+    "Anti-LLM Scan OCEL Authority",
+    None
+);
