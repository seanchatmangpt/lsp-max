--- a/src/diagnostic.rs
+++ b/src/diagnostic.rs
@@ -84,6 +84,57 @@ pub enum CompatDiagnostic {
     /// **Satisfied by:** graduating the surface to `wasm4pm`, where an engine can
     /// discover/conform/replay rather than merely admit and tag.
     MigrationRecommended,
+
+    // ── Oracle Violations (A8–A12) ─────────────────────────────────────────────
+    // Structural law violations detected by OCEL-based anti-LLM-cheat analysis.
+    // Each variant maps to one of the five Oracle adversary classes in the
+    // lsp-max threat model. Graduate to wasm4pm for actual Oracle inference.
+
+    /// **A8 — Audit Log Tampering**
+    ///
+    /// **Law:** every receipt, diagnostic, or admission event must have an ancestor
+    /// computation event in the OCEL causal graph (hash chain must be intact).
+    ///
+    /// **Satisfied by:** ensuring all emitted events trace causally to real tool
+    /// calls, file reads, or test executions — not synthesized after the fact.
+    OracleA8AuditLogTampering,
+
+    /// **A9 — Temporal Anomaly**
+    ///
+    /// **Law:** OCEL event timestamps must respect causal ordering — ancestor events
+    /// must have earlier timestamps than descendant events.
+    ///
+    /// **Satisfied by:** ensuring session clocks are monotonic and receipts are
+    /// generated strictly after the computations they receipt.
+    OracleA9TemporalAnomaly,
+
+    /// **A10 — Causal Violation**
+    ///
+    /// **Law:** every mutation, diagnostic, or admission must be preceded by an
+    /// observation event (FileRead, ToolCall, PatternMatched) in the OCEL graph.
+    ///
+    /// **Satisfied by:** tracing every mutation to a concrete observation; never
+    /// emitting diagnostics or admissions without causal predecessors.
+    OracleA10CausalViolation,
+
+    /// **A11 — Unknown State Collapse**
+    ///
+    /// **Law:** `ConformanceVector` law-axis values must not transition
+    /// `UNKNOWN → ADMITTED` or `UNKNOWN → REFUSED` without a resolution event.
+    ///
+    /// **Satisfied by:** emitting an explicit `ResolutionEvent` (test result,
+    /// receipt validation, or refusal reason) before admitting or refusing an
+    /// axis that was previously `UNKNOWN`.
+    OracleA11UnknownCollapse,
+
+    /// **A12 — Cyclic Dependency**
+    ///
+    /// **Law:** the OCEL event causality graph must be a DAG; no event may be
+    /// its own causal ancestor.
+    ///
+    /// **Satisfied by:** ensuring tool dispatch and object reference graphs are
+    /// acyclic — no circular tool calls, no circular object dependencies.
+    OracleA12CyclicDependency,
 }
 
